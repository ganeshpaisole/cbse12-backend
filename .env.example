# ══════════════════════════════════════════════
# CBSE12 Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Admin secret for /api/usage endpoint
ADMIN_SECRET=choose-a-strong-random-password

# Port (Railway/Render auto-sets this)
PORT=3001

# Your frontend URL (for CORS)
FRONTEND_URL=https://cbseexamwala.netlify.app
